    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "mysql2": "^3.22.3",
    "pg": "^8.20.0",
    "pino": "^9.5.0",
    "prisma": "^6.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "pino-pretty": "^11.3.0",
    "prisma": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3"

{
  "name": "bms-finance-backend",
  "version": "0.1.0",
  "description": "BMS Finance Dashboard backend API (Fastify + Prisma + PostgreSQL)",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",

{
  "name": "new_finance_dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:electron": "tsc -b && cross-env VITE_BASE=/ VITE_BACKEND_URL= vite build",
    "electron:dev": "npm run build && electron .",
    "dist": "npm run build:electron && electron-builder --win --x64",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.91.2",
    "axios": "^1.13.6",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.9",
    "js-cookie": "^3.0.5",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/js-cookie": "^3.0.6",
    "@types/jszip": "^3.4.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "cross-env": "^7.0.3",
    "electron": "^36.9.5",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  },
  "build": {
    "appId": "com.hospital.medical-record-system",
    "productName": "Medical Record System",
    "copyright": "Copyright © 2025",
    "asar": true,
    "directories": {
      "output": "dist-electron",
      "buildResources": "build-resources"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://CHANGE_ME.example.com/medical-record-system/updates",
        "channel": "latest"
      }
    ],
    "files": [
      "electron/main.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "app-dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "backend-installer/dist",
        "to": "backend/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "backend-installer/node_modules",
        "to": "backend/node_modules",
        "filter": [
          "**/*",
          "!**/*.md",
          "!**/.gitignore",
          "!**/test/**",
          "!**/tests/**",
          "!**/__tests__/**"
        ]
      },
      {
        "from": "backend-installer/data",
        "to": "backend/data",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "backend-installer/package.json",
        "to": "backend/package.json"
      },
      {
        "from": "backend-installer/prisma/schema.prisma",
        "to": "backend/prisma/schema.prisma"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/bms-logo.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Medical Record System",
      "deleteAppDataOnUninstall": false,
      "artifactName": "Medical-record-system-Setup-Full.exe"
    }
  }
}
